#pragma once
#include <Vital.sandbox/API/ssao.h>


//////////////////////////////
// Vital: API: Environment //
//////////////////////////////

void Vital::Sandbox::API::Environment::bind(void* instance) {
    auto vm = Machine::to_machine(instance);

    API::bind(vm, "environment", "set_sky_custom_fov", [](auto ref) -> int {
        auto vm = Machine::fetch_machine(ref);
        return vm -> execute([&]() -> int {
            if ((vm -> get_count() < 1) || (!vm -> is_number(1))) throw Vital::Tool::Log::fetch("invalid-argument", Vital::Tool::Log::Type::Error);
            auto fov = vm -> get_float(1);
            Engine::Core::get_environment() -> set_sky_custom_fov(fov);
            vm -> push_value(true);
            return 1;
        });
    });

    API::bind(vm, "environment", "get_sky_custom_fov", [](auto ref) -> int {
        auto vm = Machine::fetch_machine(ref);
        return vm -> execute([&]() -> int {
            vm -> push_value(Engine::Core::get_environment() -> get_sky_custom_fov());
            return 1;
        });
    });

    API::bind(vm, "environment", "set_bg_energy_multiplier", [](auto ref) -> int {
        auto vm = Machine::fetch_machine(ref);
        return vm -> execute([&]() -> int {
            if ((vm -> get_count() < 1) || (!vm -> is_number(1))) throw Vital::Tool::Log::fetch("invalid-argument", Vital::Tool::Log::Type::Error);
            auto energy = vm -> get_float(1);
            Engine::Core::get_environment() -> set_bg_energy_multiplier(energy);
            vm -> push_value(true);
            return 1;
        });
    });

    API::bind(vm, "environment", "get_bg_energy_multiplier", [](auto ref) -> int {
        auto vm = Machine::fetch_machine(ref);
        return vm -> execute([&]() -> int {
            vm -> push_value(Engine::Core::get_environment() -> get_bg_energy_multiplier());
            return 1;
        });
    });
}