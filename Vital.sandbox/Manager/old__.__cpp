    void Sandbox::ready() {
        // TODO: REMOVE LATER
        std::string rwString = R"(
            print("SSAO Enabled: ", ssao.set_enabled(true))
            print("SSAO Intensity: ", ssao.get_intensity())
            print("Adjustment Enabled:", adjustment.set_enabled(true))
            print("SSAO Enabled: ", ssao.set_enabled(true))
            print("SSAO Intensity: ", ssao.set_intensity(5))
        )";
        vm -> load_string(rwString);

        font.instantiate();
        font -> load_dynamic_font(Tool::to_godot_string(get_directory()) + Tool::to_godot_string("/") + Tool::to_godot_string("fonts/Roboto-Bold.ttf"));
        tex = Engine::Texture::create_texture_2d("flower.jpg");
        svg = Engine::Texture::create_svg("square.svg");
    }

